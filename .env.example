# ============================================================================
# QuShield-PnB — Environment Configuration
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in the values marked [REQUIRED] before running any code
# 3. Values marked [OPTIONAL] have working defaults or are only needed for
#    specific features
# ============================================================================

# --- PostgreSQL (the ONLY required external service for MVP) ----------------
# Install locally: sudo apt install postgresql OR use Docker:
#   docker run -d --name qushield-pg -p 5432:5432 -e POSTGRES_PASSWORD=qushield postgres:16
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=qushield
POSTGRES_USER=qushield
POSTGRES_PASSWORD=changeme_local_dev   # [REQUIRED] set your own

# --- Discovery Engine API Keys (for subdomain enumeration) ------------------
# These are OPTIONAL. subfinder works without them but returns fewer results.
# Get free keys from:
#   SecurityTrails: https://securitytrails.com/app/signup (free: 50 req/month)
#   Shodan:         https://account.shodan.io/register  (free: 100 req/month)
#   VirusTotal:     https://www.virustotal.com/gui/join-us (free: 500 req/day)
#   Censys:         https://search.censys.io/register   (free: 250 req/month)
SECURITYTRAILS_API_KEY=               # [OPTIONAL]
SHODAN_API_KEY=                       # [OPTIONAL]
VIRUSTOTAL_API_KEY=                   # [OPTIONAL]
CENSYS_API_ID=                        # [OPTIONAL]
CENSYS_API_SECRET=                    # [OPTIONAL]

# --- NVD API Key (for CVE lookups) ------------------------------------------
# Without key: 5 requests/30s. With key: 50 requests/30s.
# Get free key: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=                          # [OPTIONAL] — works without, just slower

# --- MaxMind GeoIP (for IP geolocation) -------------------------------------
# Download the free GeoLite2-City.mmdb database:
# 1. Create account: https://www.maxmind.com/en/geolite2/signup
# 2. Download GeoLite2-City.mmdb and place it in data/geolite/
MAXMIND_LICENSE_KEY=                  # [OPTIONAL] — only needed for auto-download
GEOIP_DB_PATH=data/geolite/GeoLite2-City.mmdb

# --- Ollama (for AI features — Phase 5 only) --------------------------------
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Then:    ollama pull qwen2.5:7b && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434  # [DEFAULT — change if Ollama runs elsewhere]

# --- Application Config ----------------------------------------------------
APP_ENV=development
LOG_LEVEL=DEBUG
LOG_DIR=logs
DATA_DIR=data
REPORTS_DIR=data/reports
CBOM_DIR=data/cbom
